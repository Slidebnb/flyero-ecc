  rejectedReason   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer    CustomerProfile   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  folder      DocumentFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy  User?             @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  approvedBy  User?             @relation("ApprovedDocuments", fields: [approvedById], references: [id], onDelete: SetNull)
  versions    DocumentVersion[]
  comments    DocumentComment[]

  @@index([customerId, status])
  @@index([orderId, documentType])
  @@index([folderId])
  @@index([status, uploadedAt])
  @@index([documentType, status])
  @@index([orderId, customerVisible])
  @@index([providerName, reportDate])
  @@index([uploadedById])
  @@index([approvedById])
  @@index([checksum])
}

model ManualDistributor {
  id                    String   @id @default(cuid())
  name                  String
  phone                 String?
  email                 String?
  region                String?
  vehicle               String?
  isActive              Boolean  @default(true)
  notes                 String?
  compensationType      String?
  reliabilityNote       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isActive, region])
  @@index([name])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  version      Int
  storageKey   String?
  fileUrl      String
  checksum     String
  uploadedById String?
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([documentId, version])
  @@index([documentId, createdAt])
  @@index([uploadedById, createdAt])
  @@index([checksum])
}

model DocumentComment {
  id         String                    @id @default(cuid())
  documentId String
  userId     String?
  visibility DocumentCommentVisibility @default(PUBLIC)
  message    String
  createdAt  DateTime                  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([documentId, createdAt])
  @@index([userId, createdAt])
  @@index([visibility])
}

model PrintPartner {
  id          String   @id @default(cuid())
  companyName String
  contactName String?
  email       String
  phone       String?
  address     Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  printOrders PrintOrder[]

  @@index([isActive])
  @@index([companyName])
  @@index([email])
}

model PrintOrder {
  id                String      @id @default(cuid())
  orderId           String
  customerId        String
  printerId         String?
  warehouseInventoryId String?
  assignedWarehouseId String?
  status            PrintStatus @default(REQUESTED)
  printFormat       String
  paperType         String
  paperWeight       Int
  colorMode         String
  doubleSided       Boolean     @default(true)
  folded            String?
  finishing         String?
  quantity          Int
  notes             String?
  estimatedDelivery DateTime?
  trackingNumber    String?
  estimatedNetPrice Decimal?    @db.Decimal(12, 2)
  estimatedGrossPrice Decimal?  @db.Decimal(12, 2)
  priceSnapshot     Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer  CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  printer   PrintPartner?    @relation(fields: [printerId], references: [id], onDelete: SetNull)
  warehouseInventory WarehouseInventory? @relation(fields: [warehouseInventoryId], references: [id], onDelete: SetNull)
  assignedWarehouse Warehouse? @relation("PrintOrderAssignedWarehouse", fields: [assignedWarehouseId], references: [id], onDelete: SetNull)
  logisticsShipments LogisticsShipment[]

  @@index([orderId, status])
  @@index([customerId, status])
  @@index([printerId, status])
  @@index([warehouseInventoryId])
  @@index([assignedWarehouseId])
  @@index([status, createdAt])
}

model TicketMessage {
  id         String                  @id @default(cuid())
  ticketId   String
  senderId   String?
  senderRole UserRole?
  visibility TicketMessageVisibility @default(PUBLIC)
  message    String
  createdAt  DateTime                @default(now())

  ticket      SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?              @relation(fields: [senderId], references: [id], onDelete: SetNull)
  attachments TicketAttachment[]

  @@index([ticketId, createdAt])
  @@index([senderId, createdAt])
  @@index([visibility])
}

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  messageId    String?
  fileUrl      String
  fileName     String
  fileType     String
  uploadedById String?
  createdAt    DateTime @default(now())

  ticket     SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message    TicketMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploadedBy User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([messageId])
  @@index([uploadedById, createdAt])
}

model Lead {
  id                    String       @id @default(cuid())
  type                  LeadType
  name                  String
  companyName           String?
  email                 String
  phone                 String?
  city                  String?
  message               String
  status                LeadStatus   @default(NEW)
  priority              LeadPriority @default(NORMAL)
  source                String       @default("website")
  sourceCampaign        String?
  assignedToId          String?
  nextFollowUpAt        DateTime?
  lastContactedAt       DateTime?
  estimatedOrderVolume  Decimal?     @db.Decimal(12, 2)
  expectedFlyerQuantity Int?
  notes                 String?
  lostReason            String?
  wonCustomerId         String?
  adminNote             String?
  archivedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  assignedTo User?            @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  wonCustomer CustomerProfile? @relation("WonLeads", fields: [wonCustomerId], references: [id], onDelete: SetNull)
  leadNotes   LeadNote[]
  activities  LeadActivity[]

  @@index([type, status])
  @@index([status, createdAt])
  @@index([priority, status])
  @@index([assignedToId])
  @@index([nextFollowUpAt])
  @@index([wonCustomerId])
  @@index([archivedAt])
  @@index([email])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([authorId, createdAt])
}

model LeadActivity {
  id         String      @id @default(cuid())
  leadId     String
  actorId    String?
  event      String
  fromStatus LeadStatus?
  toStatus   LeadStatus?
  detail     String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([event, createdAt])
  @@index([actorId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  metadata   Json?
  requestId  String?
  ipAddress  String?
  userAgent  String?
  result     String   @default("SUCCESS")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([requestId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model NotificationTemplate {
  id           String               @id @default(cuid())
  key          String               @unique
  audience     NotificationAudience
  channel      NotificationChannel  @default(EMAIL)
  name         String
  description  String?
  subject      String
  body         String
  placeholders String[]
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  messages NotificationMessage[]
  queues   NotificationQueue[]
  logs     NotificationLog[]

  @@index([audience, channel, isActive])
  @@index([key])
}

model NotificationMessage {
  id         String               @id @default(cuid())
  userId     String
  templateId String?
  type       String
  audience   NotificationAudience
  channel    NotificationChannel  @default(IN_APP)
  subject    String
  body       String
  data       Json?
  readAt     DateTime?
  createdAt  DateTime             @default(now())

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  queues   NotificationQueue[]
  logs     NotificationLog[]

  @@index([userId, readAt])
  @@index([type, createdAt])
  @@index([audience, channel, createdAt])
}

model NotificationQueue {
  id                String                  @id @default(cuid())
  messageId         String
  templateId        String?
  userId            String
  channel           NotificationChannel
  status            NotificationQueueStatus @default(PENDING)
  attempts          Int                     @default(0)
  maxAttempts       Int                     @default(3)
  scheduledAt       DateTime                @default(now())
  sentAt            DateTime?
  failedAt          DateTime?
  lastError         String?
  provider          String?
  providerMessageId String?
  payload           Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  message  NotificationMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs     NotificationLog[]

  @@index([status, scheduledAt])
  @@index([userId, status])
  @@index([channel, status])
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  type      String
  channel   NotificationChannel @default(EMAIL)
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId, enabled])
}

model NotificationLog {
  id         String                   @id @default(cuid())
  messageId  String?
  queueId    String?
  templateId String?
  userId     String?
  action     String
  status     NotificationQueueStatus?
  detail     String?
  metadata   Json?
  createdAt  DateTime                 @default(now())

  message  NotificationMessage?  @relation(fields: [messageId], references: [id], onDelete: SetNull)
  queue    NotificationQueue?    @relation(fields: [queueId], references: [id], onDelete: SetNull)
  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user     User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([queueId, createdAt])
  @@index([templateId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SystemLog {
  id        String         @id @default(cuid())
  level     SystemLogLevel
  source    String
  message   String
  metadata  Json?
  createdAt DateTime       @default(now())

  @@index([level, createdAt])
  @@index([source, createdAt])
}

model ErrorLog {
  id             String        @id @default(cuid())
  severity       ErrorSeverity
  source         String
  message        String
  stack          String?
  metadata       Json?
  status         ErrorStatus   @default(OPEN)
  resolvedById   String?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  resolvedBy User? @relation("ResolvedErrorLogs", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([severity, status, createdAt])
  @@index([source, createdAt])
  @@index([resolvedById, resolvedAt])
}

model SystemHealthCheck {
  id               String       @id @default(cuid())
  status           HealthStatus
  databaseStatus   HealthStatus
  storageStatus    HealthStatus
  stripeStatus     HealthStatus
  googleMapsStatus HealthStatus
  emailStatus      HealthStatus
  queueStatus      HealthStatus
  checkedAt        DateTime     @default(now())
  metadata         Json?

  @@index([status, checkedAt])
  @@index([checkedAt])
}

model BackgroundJobLog {
  id           String              @id @default(cuid())
  jobType      String
  status       BackgroundJobStatus
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?
  metadata     Json?

  @@index([jobType, status, startedAt])
  @@index([status, startedAt])
}
