generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  DISTRIBUTOR
  WAREHOUSE_STAFF
  ADMIN
  SUPPORT_DISPATCHER
}

enum UserStatus {
  ACTIVE
  EMAIL_UNVERIFIED
  DISABLED
  BANNED
}

enum DistributorReviewStatus {
  REGISTERED
  EMAIL_VERIFIED
  PROFILE_INCOMPLETE
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
  BANNED
}

enum MobilityType {
  WALK
  BIKE
  CAR
}

enum DistributorDocumentStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ServiceType {
  FLYER_DISTRIBUTION
  DOOR_HANGER
  BROCHURE
  MAGAZINE
}

enum DistributionAreaType {
  POSTAL_CODE
  CITY
  DISTRICT
  POLYGON
  RADIUS
  CUSTOM
  DELIVERY_ZONE
}

enum DistributionAreaStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum HouseholdEstimateMethod {
  MANUAL
  SEED
  IMPORT
  AUTOMATIC
  ADMIN_ENTRY
  OFFICIAL_IMPORT
  LICENSED_IMPORT
  AREA_INTERPOLATION
  BUILDING_ESTIMATE
}

enum AreaDataSourceType {
  SEED
  ADMIN
  OFFICIAL
  LICENSED
  IMPORTED
  ESTIMATED
}

enum OrderStatus {
  DRAFT
  PAYMENT_PENDING
  PAYMENT_FAILED
  SUBMITTED
  UNDER_REVIEW
  PAID_WAITING_FOR_ADMIN_REVIEW
  WAITING_FOR_CUSTOMER
  APPROVED
  REJECTED
  CANCELLED
  READY_FOR_FLYERS
  FLYERS_EXPECTED
  FLYERS_RECEIVED
  STORED
  READY_FOR_PICKUP
  READY_FOR_DISTRIBUTION
  DISTRIBUTION_APPROVED
  REPORT_READY_PREVIEW
}

enum WarehouseItemStatus {
  EXPECTED
  RECEIVED
  STORED
  PICKUP_READY
  PICKED_UP
  PARTIALLY_RETURNED
  RETURNED
  DISPOSED
}

enum WarehouseInventoryStatus {
  FLYERS_EXPECTED
  FLYERS_RECEIVED
  STORED
  READY_FOR_PICKUP
  PICKED_UP
  RETURNED
}

enum RemainingStockStatus {
  NOT_RELEVANT
  ALLE_VERTEILT
  RESTBESTAND
  ENTSORGT
  RUECKVERSAND
}

enum PickupStatus {
  NOT_PREPARED
  PREPARED
  RESERVED
  PICKED_UP
  CANCELLED
}

enum DispatchAssignmentStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  CANCELLED
  REASSIGNED
}

enum DispatchRejectionReason {
  KEINE_ZEIT
  KRANK
  ZU_WEIT
  SONSTIGES
}

enum AutoDispatchRecommendationStatus {
  SUGGESTED
  SELECTED
  DISMISSED
  EXPIRED
}

enum TourStatus {
  PLANNED
  ASSIGNED
  READY
  PICKED_UP
  PICKUP_CONFIRMED
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_CLARIFICATION
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVIEW
}

enum ReportStatus {
  DRAFT
  DATA_INCOMPLETE
  GENERATED
  READY_FOR_REVIEW
  IN_REVIEW
  CHANGES_REQUIRED
  APPROVED
  PUBLISHED
  ARCHIVED
  RELEASED_TO_CUSTOMER
  REGENERATING
}

enum InternalReviewStatus {
  NOT_REVIEWED
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_CORRECTION
}

enum ReportType {
  DISTRIBUTION_PROOF
}

enum ReportTemplate {
  STANDARD
  IMMOBILIEN
  RESTAURANT
  FRANCHISE
  CUSTOM_BRANDING
}

enum ReportSource {
  EXTERNAL_GPS_REPORT
  MANUAL_EVIDENCE
  INTERNAL_TRACKING
  HYBRID
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

enum CreditNoteStatus {
  PREPARED
  ISSUED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  CHECKOUT_CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundType {
  FULL
  PARTIAL
}

enum RefundStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
}

enum AccountingExportType {
  INVOICES
  PAYMENTS
  CREDIT_NOTES
  FULL_ACCOUNTING
}

enum AccountingExportStatus {
  DRAFT
  GENERATING
  COMPLETED
  FAILED
  ARCHIVED
}

enum AccountingExportFormat {
  CSV_LEXWARE
  CSV_DATEV
  CSV_GENERIC
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  WAITING_INTERNAL
  RESOLVED
  REJECTED
  CLOSED
}

enum TicketType {
  CUSTOMER_SUPPORT
  COMPLAINT
  TOUR_ISSUE
  WAREHOUSE_ISSUE
  BILLING_ISSUE
  TECHNICAL_ISSUE
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketMessageVisibility {
  PUBLIC
  INTERNAL
}

enum DocumentType {
  FLYER_PDF
  PRINT_FILE
  INDESIGN
  ILLUSTRATOR
  LOGO
  IMAGE
  ZIP
  REPORT
  INVOICE
  CONTRACT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum DocumentCommentVisibility {
  PUBLIC
  INTERNAL
}

enum PrintStatus {
  REQUESTED
  APPROVED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  RECEIVED_IN_WAREHOUSE
  READY_FOR_DISTRIBUTION
  CANCELLED
}

enum ShipmentType {
  CUSTOMER_TO_WAREHOUSE
  PRINTER_TO_WAREHOUSE
  WAREHOUSE_TO_WAREHOUSE
  WAREHOUSE_TO_DISTRIBUTOR
  RETURN_TO_CUSTOMER
  DISPOSAL
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  RECEIVED
  DAMAGED
  LOST
  CANCELLED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum NotificationAudience {
  CUSTOMER
  DISTRIBUTOR
  ADMIN
  INTERNAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  SMS
  PUSH
}

enum NotificationQueueStatus {
  PENDING
  SENDING
  SENT
  FAILED
  RETRY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  OFFER_SENT
  TEST_ORDER_PLANNED
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LeadType {
  CUSTOMER
  DISTRIBUTOR
  PARTNER
  OTHER
}

enum SystemLogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ErrorStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum HealthStatus {
  OK
  DEGRADED
  DOWN
}

enum BackgroundJobStatus {
  STARTED
  SUCCESS
  FAILED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  role          UserRole
  warehouseId   String?
  status        UserStatus @default(EMAIL_UNVERIFIED)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  customerProfile    CustomerProfile?
  authSessions       AuthSession[]
  distributorProfile DistributorProfile?
  uploadedPhotos     PhotoProof[]        @relation("UploadedPhotos")
  approvedReports    Report[]            @relation("ApprovedReports")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  orderStatusEvents  OrderStatusEvent[]
  warehouseHistories WarehouseHistory[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  accountingExports  AccountingExport[]
  assignedDispatches DispatchAssignment[] @relation("DispatchAssignedBy")
  createdAreas       DistributionArea[]   @relation("AreaCreatedBy")
  areaEstimates      AreaHouseholdEstimate[] @relation("AreaEstimateCreatedBy")
  areaHistories      AreaHistory[]        @relation("AreaHistoryUser")
  notificationMessages NotificationMessage[]
  notificationQueues NotificationQueue[]
  notificationPreferences NotificationPreference[]
  notificationLogs   NotificationLog[]
  resolvedErrorLogs  ErrorLog[]          @relation("ResolvedErrorLogs")
  assignedLeads      Lead[]              @relation("AssignedLeads")
  leadNotes          LeadNote[]
  leadActivities     LeadActivity[]
  assignedTickets    SupportTicket[]     @relation("AssignedTickets")
  createdTickets     SupportTicket[]     @relation("CreatedTickets")
  ticketMessages     TicketMessage[]
  ticketAttachments  TicketAttachment[]
  uploadedDocuments  Document[]          @relation("UploadedDocuments")
  approvedDocuments  Document[]          @relation("ApprovedDocuments")
  documentVersions   DocumentVersion[]
  documentComments   DocumentComment[]
  warehouse          Warehouse? @relation("WarehouseStaff", fields: [warehouseId], references: [id], onDelete: SetNull)
  receivedShipments  LogisticsShipment[] @relation("ShipmentReceivedBy")
  requestedTransfers WarehouseTransfer[] @relation("TransferRequestedBy")
  approvedTransfers  WarehouseTransfer[] @relation("TransferApprovedBy")
  stockCounts        WarehouseStockCount[] @relation("StockCountedBy")
  orderExperienceEvents OrderExperienceEvent[]

  @@index([role, status])
  @@index([warehouseId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt, expiresAt])
}

model AuthRateLimitBucket {
  id              String    @id
  windowStartedAt DateTime
  attempts        Int       @default(0)
  blockedUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([blockedUntil])
  @@index([updatedAt])
}

model CustomerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String
  contactName    String
  phone          String
  billingAddress Json
  deliveryAddress Json?
  vatId          String?
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         Order[]
  distributionAreas DistributionArea[]
  reports        Report[]
  payments       Payment[]
  invoices       Invoice[]
  supportTickets SupportTicket[]
  documents      Document[]
  printOrders    PrintOrder[]
  wonLeads       Lead[] @relation("WonLeads")
  orderExperienceEvents OrderExperienceEvent[]

  @@index([companyName])
}

model DistributorProfile {
  id             String                  @id @default(cuid())
  userId         String                  @unique
  firstName      String
  lastName       String
  birthDate      DateTime
  address        Json
  federalState   String
  phone          String
  mobilityType   MobilityType?
  mobilityTypes  MobilityType[]
  preferredAreas String[]
  availability   Json
  workingTimes   String[]
  serviceRadiusKm Int
  maxToursPerDay Int                     @default(3)
  maxFlyersPerDay Int                    @default(8000)
  currentAssignedFlyers Int              @default(0)
  currentAssignedTours Int               @default(0)
  availableToday Boolean                 @default(true)
  rating        Decimal                  @default(4.50) @db.Decimal(3, 2)
  completedToursCount Int                @default(0)
  idDocumentStatus DistributorDocumentStatus @default(NOT_SUBMITTED)
  driverLicenseStatus DistributorDocumentStatus @default(NOT_SUBMITTED)
  businessDocumentStatus DistributorDocumentStatus @default(NOT_SUBMITTED)
  taxNumber      String?
  bankAccount    Json?
  reviewStatus   DistributorReviewStatus @default(PENDING_REVIEW)
  adminNotes     String?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedOrders Order[]           @relation("AssignedDistributor")
  tours         DistributionTour[]
  reservedInventories WarehouseInventory[]
  dispatchAssignments DispatchAssignment[]
  autoDispatchRecommendations AutoDispatchRecommendation[]
  supportTickets SupportTicket[]

  @@index([reviewStatus])
  @@index([mobilityType])
  @@index([reviewStatus, availableToday])
}

model Order {
  id                   String      @id @default(cuid())
  orderNumber          String      @unique
  customerId           String
  status               OrderStatus @default(SUBMITTED)
  serviceType          ServiceType @default(FLYER_DISTRIBUTION)
  city                 String
  postalCode           String
  targetAddress        Json
  targetLat            Decimal?    @db.Decimal(10, 7)
  targetLng            Decimal?    @db.Decimal(10, 7)
  targetAreaName       String
  targetAreaGeoJson    Json?
  estimatedHouseholds  Int?
  estimatedFlyers      Int?
  estimatedDistanceMeters Int?
  coverageAreaSqm      Decimal?    @db.Decimal(14, 2)
  distributionAreaId   String?
  flyerQuantity        Int
  customerOwnFlyers    Boolean     @default(true)
  needsPrintService    Boolean     @default(false)
  preferredStartDate   DateTime
  preferredEndDate     DateTime
  flexibleScheduling   Boolean     @default(false)
  contactPerson        String?
  contactPhone         String?
  notes                String?
  adminInternalNotes   String?
  adminCustomerMessage String?
  calculatedNetPrice   Decimal     @db.Decimal(12, 2)
  calculatedVat        Decimal     @db.Decimal(12, 2)
  calculatedGrossPrice Decimal     @db.Decimal(12, 2)
  manualPriceOverride  Decimal?    @db.Decimal(12, 2)
  priceRuleSnapshot    Json
  assignedDistributorId String?
  assignedWarehouseId   String?
  warehouseAssignedAt   DateTime?
  warehouseAssignmentReason String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  customer            CustomerProfile     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  distributionArea    DistributionArea?   @relation(fields: [distributionAreaId], references: [id], onDelete: SetNull)
  assignedDistributor DistributorProfile? @relation("AssignedDistributor", fields: [assignedDistributorId], references: [id], onDelete: SetNull)
  assignedWarehouse   Warehouse?          @relation("AssignedWarehouseOrders", fields: [assignedWarehouseId], references: [id], onDelete: SetNull)
  warehouseItem       WarehouseItem?
  tours               DistributionTour[]
  photoProofs         PhotoProof[]
  reports             Report[]
  deviations          DistributionDeviation[]
  payments            Payment[]
  invoice             Invoice?
  supportTickets      SupportTicket[]
  documents           Document[]
  documentFolders     DocumentFolder[]
  printOrders         PrintOrder[]
  statusEvents        OrderStatusEvent[]
  warehouseInventory  WarehouseInventory?
  dispatchAssignments DispatchAssignment[]
  autoDispatchRecommendations AutoDispatchRecommendation[]
  logisticsShipments LogisticsShipment[]
  experienceEvents   OrderExperienceEvent[]

  @@index([customerId, status])
  @@index([distributionAreaId])
  @@index([assignedDistributorId])
  @@index([assignedWarehouseId])
  @@index([city])
  @@index([status, createdAt])
  @@index([serviceType])
}

model OrderExperienceEvent {
  id             String   @id @default(cuid())
  orderId        String?
  customerId     String?
  userId         String?
  eventType      String
  source         String   @default("order-wizard")
  city           String?
  postalCode     String?
  areaName       String?
  areaType       DistributionAreaType?
  durationMs     Int?
  clickCount     Int?
  fieldCount     Int?
  usedAutocomplete Boolean @default(false)
  usedSavedArea  Boolean  @default(false)
  polygonPoints  Int?
  households     Int?
  flyerQuantity  Int?
  coverageAreaSqm Decimal? @db.Decimal(14, 2)
  routeDistanceMeters Int?
  routeDurationMinutes Int?
  metadata       Json?
  createdAt      DateTime @default(now())

  order    Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([customerId, createdAt])
  @@index([city, createdAt])
  @@index([postalCode, createdAt])
  @@index([orderId])
}

model DistributionArea {
  id                       String                 @id @default(cuid())
  name                     String
  slug                     String                 @unique
  type                     DistributionAreaType
  status                   DistributionAreaStatus @default(ACTIVE)
  reusable                 Boolean                @default(true)
  city                     String?
  postalCode               String?
  district                 String?
  state                    String?
  country                  String                 @default("DE")
  centerLat                Decimal?               @db.Decimal(10, 7)
  centerLng                Decimal?               @db.Decimal(10, 7)
  radiusMeters             Int?
  geoJson                  Json?
  geometryGeoJson          Json?
  coverageAreaSqm          Decimal?               @db.Decimal(14, 2)
  areaKm2                  Decimal?               @db.Decimal(12, 6)
  estimatedHouseholds      Int?
  estimatedFlyers          Int?
  estimatedDistanceMeters  Int?
  googlePlaceId            String?
  googleFeatureType        String?
  dataSourceName           String?
  dataSourceType           AreaDataSourceType      @default(SEED)
  dataSourceUrl            String?
  licenseNote              String?
  dataUpdatedAt            DateTime?
  confidence               Decimal?               @db.Decimal(4, 3)
  createdById              String?
  customerId               String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  createdBy User? @relation("AreaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  customer  CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  polygons  AreaPolygon[]
  estimates AreaHouseholdEstimate[]
  history   AreaHistory[]
  orders    Order[]

  @@index([type, status])
  @@index([city])
  @@index([city, postalCode])
  @@index([dataSourceType, dataUpdatedAt])
  @@index([googlePlaceId])
  @@index([customerId, status])
  @@index([createdById])
}

model AreaPolygon {
  id              String   @id @default(cuid())
  areaId          String
  sortOrder       Int      @default(0)
  geometry        Json
  areaSqm         Decimal? @db.Decimal(14, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  area DistributionArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, sortOrder])
}

model AreaHouseholdEstimate {
  id             String                  @id @default(cuid())
  areaId         String
  households     Int
  estimatedHouseholds Int?
  estimatedResidents Int?
  estimatedDwellings Int?
  residentialBuildings Int?
  estimatedFlyers Int?
  distanceMeters Int?
  coverageAreaSqm Decimal?              @db.Decimal(14, 2)
  method         HouseholdEstimateMethod @default(MANUAL)
  source         String?
  sourceUrl      String?
  sourceYear     Int?
  confidence     Decimal?                @db.Decimal(4, 3)
  notes          String?
  validFrom      DateTime?
  validTo        DateTime?
  createdById    String?
  createdAt      DateTime                @default(now())

  area      DistributionArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("AreaEstimateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([areaId, createdAt])
  @@index([method])
  @@index([sourceYear])
  @@index([validFrom, validTo])
}

model AreaHistory {
  id        String   @id @default(cuid())
  areaId    String
  userId    String?
  action    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  area DistributionArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  user User?            @relation("AreaHistoryUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([areaId, createdAt])
  @@index([userId, createdAt])
}

model OrderStatusEvent {
  id         String      @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?
  createdAt  DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([changedBy, createdAt])
}

model PricingSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  valueDecimal Decimal  @db.Decimal(12, 4)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PricingRule {
  id            String      @id @default(cuid())
  serviceType   ServiceType @default(FLYER_DISTRIBUTION)
  minQuantity   Int
  maxQuantity   Int?
  pricePerUnit  Decimal     @db.Decimal(12, 4)
  basePrice     Decimal     @db.Decimal(12, 2)
  minimumNetPrice Decimal   @db.Decimal(12, 2)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([serviceType, isActive])
  @@index([minQuantity, maxQuantity])
}

model Warehouse {
  id                 String   @id @default(cuid())
  name               String
  code               String   @unique
  address            Json
  city               String
  postalCode         String
  country            String   @default("DE")
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  region             String?
  isActive           Boolean  @default(true)
  isDefault          Boolean  @default(false)
  openingHours       String?
  contactPerson      String?
  contactPhone       String?
  contactEmail       String?
  capacityLimit      Int?
  currentUtilization Int      @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  locations          WarehouseLocation[]
  regions            WarehouseRegion[]
  staff              User[] @relation("WarehouseStaff")
  assignedOrders     Order[] @relation("AssignedWarehouseOrders")
  inventories        WarehouseInventory[]
  printOrders        PrintOrder[] @relation("PrintOrderAssignedWarehouse")
  shipments          LogisticsShipment[]
  transfersFrom      WarehouseTransfer[] @relation("TransferFromWarehouse")
  transfersTo        WarehouseTransfer[] @relation("TransferToWarehouse")
  stockCounts        WarehouseStockCount[]

  @@index([city])
  @@index([city, postalCode])
  @@index([code])
  @@index([isActive, isDefault])
}

model WarehouseRegion {
  id             String   @id @default(cuid())
  warehouseId    String
  name           String
  city           String?
  postalCodes    String[]
  radiusKm       Int?
  polygonGeoJson Json?
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([warehouseId, isActive])
  @@index([city])
  @@index([priority])
}

model CompanySettings {
  id          String   @id @default(cuid())
  companyName String
  legalName   String
  street      String
  postalCode  String
  city        String
  country     String   @default("DE")
  phone       String?
  email       String?
  website     String?
  taxNumber   String?
  vatId       String?
  bankName    String?
  iban        String?
  bic         String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandingSettings {
  id                String   @id @default(cuid())
  primaryColor      String   @default("#102033")
  secondaryColor    String   @default("#176b36")
  accentColor       String   @default("#e0b84d")
