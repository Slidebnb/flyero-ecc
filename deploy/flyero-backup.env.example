# Diese Datei als /etc/flyero/backup.env mit root:root und chmod 600 anlegen.
# Keine Passwoerter oder privaten Schluessel in Git speichern.
ENV_FILE=/opt/flyero/.env.production
COMPOSE_FILE=/opt/flyero/docker-compose.production.yml
BACKUP_RESTIC_REPOSITORY=sftp:backup-user@storagebox.example:/home/backup-user/flyero
BACKUP_RESTIC_PASSWORD_FILE=/etc/flyero/restic-password
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
