GOOGLE_MAPS_SERVER_KEY=""

# Private S3-compatible object storage for documents, photos and generated reports.
FILE_STORAGE_PROVIDER="s3"
FILE_SCAN_MODE="required"
CLAMSCAN_PATH="/usr/bin/clamscan"
S3_ENDPOINT="https://s3.example.com"
S3_REGION="eu-central-1"
S3_BUCKET="flyero-private"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
S3_PREFIX="flyero"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
ENABLE_MOCK_PAYMENTS="false"
SEED_DEMO_DATA="false"
INTERNAL_API_TOKEN="replace-with-a-long-random-internal-api-token"

BACKUP_RESTIC_REPOSITORY=""
BACKUP_RESTIC_PASSWORD_FILE="/etc/flyero/restic-password"
BACKUP_RETENTION_DAILY="7"
BACKUP_RETENTION_WEEKLY="4"
BACKUP_RETENTION_MONTHLY="12"
BACKUP_READ_DATA_SUBSET="1/20"
PAYMENT_RECONCILIATION_LIMIT="500"
