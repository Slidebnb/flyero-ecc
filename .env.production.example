POSTGRES_DB="flyero"
POSTGRES_USER="flyero"
POSTGRES_PASSWORD="replace-with-a-long-random-database-password"

DATABASE_URL="postgresql://flyero:replace-with-a-long-random-database-password@postgres:5432/flyero?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
APP_URL="https://flyero.org"
NEXT_PUBLIC_SITE_URL="https://flyero.org"

EMAIL_PROVIDER="resend"
EMAIL_FROM="FLYERO <hallo@flyero.org>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
RESEND_API_KEY=""

AUTH_LOGIN_IP_RATE_LIMIT_MAX="10"
AUTH_LOGIN_IP_RATE_LIMIT_WINDOW_MS="900000"
PUBLIC_LEAD_RATE_LIMIT_MAX="5"
PUBLIC_LEAD_RATE_LIMIT_WINDOW_MS="600000"
PUBLIC_REPORT_VERIFY_RATE_LIMIT_MAX="30"
PUBLIC_REPORT_VERIFY_RATE_LIMIT_WINDOW_MS="900000"
PUBLIC_MAPS_RATE_LIMIT_MAX="60"
PUBLIC_MAPS_RATE_LIMIT_WINDOW_MS="900000"
PUBLIC_CLIENT_ERROR_RATE_LIMIT_MAX="30"
PUBLIC_CLIENT_ERROR_RATE_LIMIT_WINDOW_MS="900000"
AUTH_LOGIN_ACCOUNT_RATE_LIMIT_MAX="5"
AUTH_LOGIN_ACCOUNT_RATE_LIMIT_WINDOW_MS="900000"
AUTH_REGISTER_IP_RATE_LIMIT_MAX="5"
AUTH_REGISTER_IP_RATE_LIMIT_WINDOW_MS="3600000"
AUTH_RESEND_IP_RATE_LIMIT_MAX="3"
AUTH_RESEND_IP_RATE_LIMIT_WINDOW_MS="3600000"
AUTH_VERIFY_IP_RATE_LIMIT_MAX="10"
AUTH_VERIFY_IP_RATE_LIMIT_WINDOW_MS="900000"
AUTH_PASSWORD_RESET_IP_RATE_LIMIT_MAX="5"
AUTH_PASSWORD_RESET_IP_RATE_LIMIT_WINDOW_MS="3600000"

NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=""
