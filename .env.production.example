POSTGRES_DB="flyero"
POSTGRES_USER="flyero"
POSTGRES_PASSWORD="replace-with-a-long-random-database-password"

DATABASE_URL="postgresql://flyero:replace-with-a-long-random-database-password@postgres:5432/flyero?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
APP_URL="https://flyero.org"
